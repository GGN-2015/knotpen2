#: ../Knotpen2GameObject.py:470
msgid "基础编辑"
msgstr "Basic editing"

#: ../Knotpen2GameObject.py:471
msgid "左键空白处创建节点；拖拽节点可以移动。"
msgstr "Left-click empty space to create a node; drag a node to move it."

#: ../Knotpen2GameObject.py:472
msgid "右键节点或边可以删除。"
msgstr "Right-click a node or edge to delete it."

#: ../Knotpen2GameObject.py:473
msgid "双击边的中点可以拆分边。"
msgstr "Double-click the middle of an edge to split it."

#: ../Knotpen2GameObject.py:474
msgid "点击交叉点可以切换相交线段的上下关系。"
msgstr "Click a crossing to switch which segment is above the other."

#: ../Knotpen2GameObject.py:476
msgid "连续创建"
msgstr "Continuous creation"

#: ../Knotpen2GameObject.py:477
msgid "点击节点进入连续创建模式，红色节点是当前选中点。"
msgstr "Click a node to enter continuous creation mode; the red node is selected."

#: ../Knotpen2GameObject.py:478
msgid "在空白处继续左键点击会创建新节点并自动连边。"
msgstr "Left-click empty space to create another node and connect it automatically."

#: ../Knotpen2GameObject.py:479
msgid "点击现有节点可以闭合曲线并退出连续创建模式。"
msgstr "Click an existing node to close the curve and leave continuous creation mode."

#: ../Knotpen2GameObject.py:481
msgid "右侧按钮"
msgstr "Right-side buttons"

#: ../Knotpen2GameObject.py:482
msgid "使用视图移动按钮平移画面。"
msgstr "Use the view movement buttons to pan the diagram."

#: ../Knotpen2GameObject.py:483
msgid "选中节点后可以设为起始点或方向点，也可以删除选中点。"
msgstr "After selecting a node, set it as the base or direction node, or delete it."

#: ../Knotpen2GameObject.py:484
msgid "清空全部会先自动备份；恢复存档会读取上一次自动保存。"
msgstr "Clear all creates a backup first; recover save loads the latest auto-save."

#: ../Knotpen2GameObject.py:485
msgid "增大窗口和减小窗口会调整窗口尺寸，并保持窗口不超过屏幕范围。"
msgstr "Increase window and decrease window resize the window while keeping it within the screen."

#: ../Knotpen2GameObject.py:486
msgid "切换语言会影响之后绘制的按钮和帮助文字。"
msgstr "Switch language affects buttons and help text drawn afterward."

#: ../Knotpen2GameObject.py:488
msgid "计算前请确保每个节点恰好有两条边。"
msgstr "Before calculating, make sure every node has exactly two edges."

#: ../Knotpen2GameObject.py:489
msgid "每个连通分支必须有相邻的起始点和方向点。"
msgstr "Each connected component must have adjacent base and direction nodes."

#: ../Knotpen2GameObject.py:490
msgid "请人工确认没有三线共点。"
msgstr "Manually confirm that no three segments meet at one point."

#: ../Knotpen2GameObject.py:530
msgid "再次点击右侧的帮助按钮关闭此页面。"
msgstr "Click the help button on the right again to close this page."

#: ../Knotpen2GameObject.py:304
msgid "正在自动保存请不要关闭软件 ..."
msgstr "Auto-saving in progress, please do not force to quit ..."

#: ../MemoryObject.py:15
msgid "正在加载自动保存的存档 ..."
msgstr "Loading auto-saved archive ..."

#: ../MemoryObject.py:19
msgid "加载失败，自动存档文件故障"
msgstr "Loading failed, auto-saved file is corrupted"

#: ../MemoryObject.py:90
msgid "由于没有修改，因此最后一次自动保存被删除"
msgstr "No modifications, last auto-save ignored"

#: ../MemoryObject.py:291
#, python-format
msgid "找到一条原有的边：%s"
msgstr "Existing edge found: %s"

#: ../MemoryObject.py:302
#, python-format
msgid "创建了一条新的边: %s"
msgstr "New edge created: %s"

#: ../MyAlgorithm.py:78
msgid "你至少要放置 3 个节点才能计算 PD_CODE"
msgstr "To calculate PD_CODE, at least 3 nodes are needed"

#: ../MyAlgorithm.py:85
#, python-format
msgid "节点 %d 所在的连通分支没有定义起始点"
msgstr "Component(begins with node %d) has no base node"

#: ../MyAlgorithm.py:88
#, python-format
msgid "节点 %d 所在的连通分支没有定义了太多起始点"
msgstr "Component(begins with node %d) has more than one base node"

#: ../MyAlgorithm.py:91
#, python-format
msgid "节点 %d 所在的连通分支没有定义方向点"
msgstr "Component(begins with node %d) has no target node"

#: ../MyAlgorithm.py:94
#, python-format
msgid "节点 %d 所在的连通分支没有定义了太多方向点"
msgstr "Component(begins with node %d) has more than one target node"

#: ../MyAlgorithm.py:102
#, python-brace-format
msgid "起始点 {base_num} 与方向点 {dirx_num} 在同一连通分支但并不相邻"
msgstr "Base node {base_num} and target node {dirx_num} should be adjacent"

#: ../MyAlgorithm.py:217
#, python-format
msgid "总计找到了 %d 个交叉点"
msgstr "totally %d crossing found"

#: ../MyAlgorithm.py:239
#, python-brace-format
msgid "连通分支 {bid} 被分割成了 {pts} 段"
msgstr "Component {bid} has been seperated into {pts} segments"

